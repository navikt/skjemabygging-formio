{
  "name": "@navikt/skjemabryggeriet",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Repository for skjemabygger og skjemautfyller",
  "repository": {
    "type": "git",
    "url": "https://github.com/navikt/skjemabygging-formio.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "workspaces": {
    "packages": [
      "packages/shared-domain",
      "packages/shared-components",
      "packages/shared-backend",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:bygger": "pnpm --filter @navikt/skjemadigitalisering-shared-domain run build && pnpm --filter @navikt/skjemadigitalisering-shared-components run build && pnpm --filter @navikt/skjemadigitalisering-shared-backend run build && concurrently --kill-others-on-fail \"pnpm --filter @navikt/bygger-backend run build\" \"pnpm --filter @navikt/bygger-frontend run build\"",
    "build:fyllut": "pnpm --filter @navikt/skjemadigitalisering-shared-domain run build && pnpm --filter @navikt/skjemadigitalisering-shared-components run build && pnpm --filter @navikt/skjemadigitalisering-shared-backend run build && concurrently --kill-others-on-fail \"pnpm --filter @navikt/fyllut-backend run build\" \"pnpm --filter @navikt/fyllut-frontend run build\"",
    "clean": "pnpm -r --if-present run clean",
    "get-tokens": "node bin/token-generator.mjs",
    "start": "concurrently --kill-others-on-fail \"pnpm run start:fyllut\" \"pnpm run start:bygger\"",
    "start:bygger": "concurrently --kill-others-on-fail \"pnpm --filter @navikt/bygger-backend run start\" \"pnpm --filter @navikt/bygger-frontend run start\"",
    "start:bygger:mocks": "node bin/start.mjs bygger",
    "start:fyllut": "concurrently --kill-others-on-fail \"pnpm --filter @navikt/fyllut-backend run start\" \"pnpm --filter @navikt/fyllut-frontend run start\"",
    "start:fyllut:mocks": "node bin/start.mjs fyllut",    
    "preview:bygger": "pnpm --filter @navikt/bygger-backend run preview",
    "preview:fyllut": "pnpm --filter @navikt/fyllut-backend run preview",
    "test": "concurrently \"pnpm --filter @navikt/bygger-frontend run test\" \"pnpm --filter @navikt/bygger-backend run test\" \"pnpm --filter @navikt/fyllut-frontend run test\" \"pnpm --filter @navikt/fyllut-backend run test\" \"pnpm --filter @navikt/skjemadigitalisering-shared-domain run test\" \"pnpm --filter @navikt/skjemadigitalisering-shared-components run test\" \"pnpm --filter @navikt/skjemadigitalisering-shared-frontend run test\" \"pnpm --filter @navikt/skjemadigitalisering-shared-backend run test\"",
    "test:nowarnings": "NODE_OPTIONS=--no-warnings pnpm test",
    "test:bygger": "concurrently \"pnpm --filter @navikt/bygger-frontend run test\" \"pnpm --filter @navikt/bygger-backend run test\"",
    "test:fyllut": "concurrently \"pnpm --filter @navikt/fyllut-frontend run test\" \"pnpm --filter @navikt/fyllut-backend run test\"",
    "test:shared-domain": "pnpm --filter @navikt/skjemadigitalisering-shared-domain run test",
    "test:shared-components": "pnpm --filter @navikt/skjemadigitalisering-shared-components run test",
    "test:shared-frontend": "pnpm --filter @navikt/skjemadigitalisering-shared-frontend run test",
    "test:shared-backend": "pnpm --filter @navikt/skjemadigitalisering-shared-backend run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "cypress:bygger": "pnpm --filter @navikt/bygger-frontend run cypress",
    "cypress:fyllut": "pnpm --filter @navikt/fyllut-frontend run cypress",
    "cypress:bygger:open": "pnpm --filter @navikt/bygger-frontend run cypress:open",
    "cypress:fyllut:open": "pnpm --filter @navikt/fyllut-frontend run cypress:open",
    "check-types": "pnpm -r --if-present run check-types",
    "mocks:fyllut": "pnpm --dir mocks run mocks:fyllut",
    "mocks:fyllut:no-cli": "pnpm --dir mocks run mocks:fyllut:no-cli",
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@navikt/aksel": "^8.1.0",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint__js": "^9.14.0",
    "@types/jest": "^30.0.0",
    "@types/react": "18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/eslint-plugin": "^1.6.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cypress": "^15.9.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-cypress": "^5.2.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.15.4",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vite-plugin-html": "^3.2.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9",
    "vitest-fetch-mock": "^0.4.5"
  },
  "engines": {
    "node": ">=24"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ]
  }
}
