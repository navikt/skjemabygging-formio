<div class="formio builder formbuilder">
  <div class="formcomponents">
    {{ctx.sidebar}}
  </div>
  <div class="formarea">
    <nav aria-label="Velg steg">
      <ol class="breadcrumb">
        {% ctx.pages.forEach(function(page, pageIndex) { %}
        <li>
          <a href="#{{page.title}}" class="wizard-page-label diff__label__parent" {% if (pageIndex === ctx.self.page) { %}aria-current="step"{% } %} ref="gotoPage">
            {{page.title}}
            {% if (ctx.config && ctx.config.formDiff && ctx.config.formDiff.diff && ctx.config.formDiff.diff.find(comp => comp.id === page.id)) { %}
              <div class="diff__label diff__label--counter diff__label--elevated">{{ctx.config.formDiff.diff.find(comp => comp.id === page.id).numberOfChanges}}</div>
            {% } %}
          </a>
        </li>
        {% }) %}
        <li>
          <button class="wizard-page-label wizard-page-label__add-new" type="button" ref="addPage">
            <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M11 13v8h2v-8h8v-2h-8V3h-2v8H3v2h8z" fill="currentColor"></path>
            </svg>
            {{ctx.t('Legg til nytt steg')}}
          </button>
        </li>
      </ol>
    </nav>
    <div ref="form">
      {{ctx.form}}
    </div>
  </div>
</div>
