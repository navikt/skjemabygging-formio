<div class = 'rune' ref="{{ctx.input.ref ? ctx.input.ref : 'selectContainer'}}"><select

  class="{{ctx.input.attr.class}} skjemaelement__test test--xxl"
  {{ ctx.input.multiple ? 'multiple' : '' }}
  {% for (var attr in ctx.input.attr) { %}
  {{attr}}="{{ctx.input.attr[attr]}}"
  {% } %}
>{{ctx.selectOptions}}</select></div>
<input type="text"
       class="formio-select-autocomplete-input"
       ref="autocompleteInput"
       {% if (ctx.input.attr.autocomplete) { %}
       autocomplete="{{ctx.input.attr.autocomplete}}"
       {% } %}
       tabindex="-1"
/>
